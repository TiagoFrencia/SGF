SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/sgf
SPRING_DATASOURCE_USERNAME=sgf
SPRING_DATASOURCE_PASSWORD=sgf
APP_JWT_SECRET=change-me-to-a-long-random-secret

APP_AFIP_ENABLED=true
APP_AFIP_MODE=SANDBOX
APP_AFIP_WS_ENVIRONMENT=HOMOLOGATION
APP_AFIP_CUIT=20123456789
APP_AFIP_POINT_OF_SALE=1

# Option 1: PEM pair
APP_AFIP_CERTIFICATE_PATH=/opt/sgf/certs/afip-homo.crt
APP_AFIP_PRIVATE_KEY_PATH=/opt/sgf/certs/afip-homo.key

# Option 2: PKCS12 / PFX / P12
APP_AFIP_PKCS12_PATH=
APP_AFIP_PKCS12_PASSWORD=
APP_AFIP_PKCS12_ALIAS=
